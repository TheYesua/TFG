# =============================================================================
# Configuración de entorno - copia este fichero a `.env` y rellena los valores
# =============================================================================

# --- Flask ---
FLASK_ENV=development
# Genera con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# --- PostgreSQL ---
POSTGRES_USER=tfg_user
POSTGRES_PASSWORD=tfg_password_cambiame
POSTGRES_DB=tfg_sa
POSTGRES_PORT=5432

# --- IA ---
# AI_PROVIDER: "openai" (API real, consume tokens), "fake" (determinista,
# sin red, para desarrollo/tests) o vacío (auto: openai si hay api key).
AI_PROVIDER=openai
# Obtén tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
OPENAI_MODEL=gpt-4o-mini

# --- Puertos expuestos en host ---
NGINX_PORT=8080
ADMINER_PORT=8081
